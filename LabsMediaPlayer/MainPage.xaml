<Page x:Class="LabsMediaPlayer.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:rss="using:LabsMediaPlayer.Rss"
      Background="{StaticResource BgBrush}">

  <Page.Resources>
    <Style x:Key="ChromeButtonStyle" TargetType="Button">
      <Setter Property="Background" Value="{StaticResource SurfaceElevatedBrush}" />
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{StaticResource Radius12}" />
      <Setter Property="Padding" Value="12,8" />
      <Setter Property="FontFamily" Value="{StaticResource FontFamilyBase}" />
      <Setter Property="FontSize" Value="{StaticResource FontSize14}" />
    </Style>

    <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
      <Setter Property="FontFamily" Value="{StaticResource FontFamilyBase}" />
      <Setter Property="FontSize" Value="{StaticResource FontSize12}" />
      <Setter Property="Margin" Value="0,0,0,6" />
    </Style>

    <DataTemplate x:Key="EpisodeItemTemplate"
                  x:DataType="rss:PodcastEpisode">
      <Border Padding="12,10"
              CornerRadius="{StaticResource Radius12}"
              BorderThickness="1"
              BorderBrush="{StaticResource BorderBrush}"
              Background="{StaticResource SurfaceBrush}">
        <StackPanel Spacing="4">
          <TextBlock Text="{x:Bind Title}"
                     TextWrapping="WrapWholeWords"
                     Foreground="{StaticResource TextBrush}"
                     FontFamily="{StaticResource FontFamilyBase}"
                     FontSize="{StaticResource FontSize16}" />
          <TextBlock Text="{x:Bind DetailLine}"
                     Foreground="{StaticResource TextMutedBrush}"
                     FontFamily="{StaticResource FontFamilyBase}"
                     FontSize="{StaticResource FontSize12}" />
        </StackPanel>
      </Border>
    </DataTemplate>
  </Page.Resources>

  <Grid x:Name="RootGrid"
        Padding="{StaticResource InsetPagePad}">
    <Border x:Name="EpisodeHost"
            Padding="0,0,0,12">
      <Grid RowSpacing="10">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="Episodes"
                   Grid.Row="0"
                   Foreground="{StaticResource TextBrush}"
                   FontFamily="{StaticResource FontFamilyBase}"
                   FontSize="{StaticResource FontSize24}" />

        <StackPanel Grid.Row="1" Spacing="6">
          <TextBlock Text="RSS feed URL"
                     Style="{StaticResource FieldLabelStyle}" />
          <TextBox x:Name="FeedUrlBox"
                   AcceptsReturn="False"
                   TextWrapping="NoWrap"
                   Foreground="{StaticResource TextBrush}"
                   Background="{StaticResource SurfaceBrush}"
                   BorderBrush="{StaticResource BorderBrush}" />
        </StackPanel>

        <StackPanel Grid.Row="2" Spacing="6">
          <TextBlock Text="CORS proxy base (recommended on WASM; GET ?url= encoded feed)"
                     Style="{StaticResource FieldLabelStyle}" />
          <TextBox x:Name="ProxyUrlBox"
                   PlaceholderText="https://your-worker.workers.dev"
                   AcceptsReturn="False"
                   Foreground="{StaticResource TextBrush}"
                   Background="{StaticResource SurfaceBrush}"
                   BorderBrush="{StaticResource BorderBrush}" />
        </StackPanel>

        <Grid Grid.Row="3"
              ColumnSpacing="10">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <TextBlock x:Name="StatusText"
                     Grid.Column="0"
                     VerticalAlignment="Center"
                     TextWrapping="WrapWholeWords"
                     Foreground="{StaticResource TextMutedBrush}"
                     FontFamily="{StaticResource FontFamilyBase}"
                     FontSize="{StaticResource FontSize12}" />
          <Button x:Name="LoadButton"
                  Grid.Column="1"
                  Content="Load feed"
                  Style="{StaticResource ChromeButtonStyle}" />
        </Grid>

        <TextBlock x:Name="RssHintText"
                   Grid.Row="4"
                   TextWrapping="WrapWholeWords"
                   Foreground="{StaticResource TextMutedBrush}"
                   FontFamily="{StaticResource FontFamilyBase}"
                   FontSize="{StaticResource FontSize12}" />

        <ListView x:Name="EpisodeList"
                  Grid.Row="5"
                  ItemsSource="{x:Bind Episodes, Mode=OneWay}"
                  ItemTemplate="{StaticResource EpisodeItemTemplate}"
                  SelectionMode="Single"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch" />
      </Grid>
    </Border>

    <Border x:Name="ChromeHost"
            Padding="16"
            Background="{StaticResource SurfaceElevatedBrush}"
            CornerRadius="{StaticResource Radius12}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1">
      <Grid RowSpacing="12">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="NowPodcastTitle"
                   Grid.Row="0"
                   TextWrapping="WrapWholeWords"
                   Foreground="{StaticResource TextBrush}"
                   FontFamily="{StaticResource FontFamilyBase}"
                   FontSize="{StaticResource FontSize20}" />

        <TextBlock x:Name="NowEpisodeTitle"
                   Grid.Row="1"
                   TextWrapping="WrapWholeWords"
                   Foreground="{StaticResource TextMutedBrush}"
                   FontFamily="{StaticResource FontFamilyBase}"
                   FontSize="{StaticResource FontSize14}" />

        <Grid Grid.Row="2">
          <!-- WASM: instantiate via code-behind would still pull Media stack; hosts hidden native element on Desktop/Android -->
          <Border x:Name="NativeAudioHost"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch" />
          <TextBlock x:Name="WasmAudioHint"
                     VerticalAlignment="Center"
                     HorizontalAlignment="Center"
                     Margin="12,8"
                     TextWrapping="WrapWholeWords"
                     TextAlignment="Center"
                     Visibility="Collapsed"
                     Foreground="{StaticResource TextMutedBrush}"
                     FontFamily="{StaticResource FontFamilyBase}"
                     FontSize="{StaticResource FontSize12}" />
        </Grid>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="10">
          <Button x:Name="PlayPauseButton"
                  Style="{StaticResource ChromeButtonStyle}">
            <SymbolIcon x:Name="PlayPauseIcon"
                        Symbol="Play" />
          </Button>
          <Button x:Name="SeekBackButton"
                  Content="-15s"
                  Style="{StaticResource ChromeButtonStyle}" />
          <Button x:Name="SeekForwardButton"
                  Content="+30s"
                  Style="{StaticResource ChromeButtonStyle}" />
        </StackPanel>

        <Slider x:Name="PositionSlider"
                Grid.Row="4"
                Minimum="0"
                Maximum="1"
                StepFrequency="0.1"
                Value="0" />

        <TextBlock x:Name="TimeLabel"
                   Grid.Row="5"
                   HorizontalAlignment="Center"
                   Foreground="{StaticResource TextMutedBrush}"
                   FontFamily="{StaticResource FontFamilyBase}"
                   FontSize="{StaticResource FontSize12}" />

        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="8">
          <TextBlock Text="Speed"
                     VerticalAlignment="Center"
                     Foreground="{StaticResource TextMutedBrush}"
                     FontFamily="{StaticResource FontFamilyBase}"
                     FontSize="{StaticResource FontSize12}" />
          <Button x:Name="Speed1Button"
                  Content="1x"
                  Style="{StaticResource ChromeButtonStyle}" />
          <Button x:Name="Speed125Button"
                  Content="1.25x"
                  Style="{StaticResource ChromeButtonStyle}" />
          <Button x:Name="Speed15Button"
                  Content="1.5x"
                  Style="{StaticResource ChromeButtonStyle}" />
          <Button x:Name="Speed2Button"
                  Content="2x"
                  Style="{StaticResource ChromeButtonStyle}" />
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Page>
